# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Feature Toggles (Set to 'false' to disable, defaults to 'true')
NEXT_PUBLIC_ENABLE_EMOJI_PICKER="true"
NEXT_PUBLIC_ENABLE_VOICE_MESSAGES="true"
NEXT_PUBLIC_ENABLE_MEDIA_ATTACHMENTS="true"
NEXT_PUBLIC_ENABLE_LINK_PREVIEWS="true"
NEXT_PUBLIC_ENABLE_CONTACT_CARD_SHARING="true"
